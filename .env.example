# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://zoomartists:zoomartists_dev@localhost:5432/zoomartists

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Storage (S3 / Cloudflare R2) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=zoomartists-media
AWS_S3_REGION=us-east-1

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:4200"]
